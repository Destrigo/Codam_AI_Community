{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpsReport",
  "type": "object",
  "required": ["title", "summary", "figures"],
  "properties": {
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "figures": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "sources": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
