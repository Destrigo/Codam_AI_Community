{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CanonicalFNOL",
  "type": "object",
  "required": [
    "policy_number",
    "loss_date",
    "loss_type",
    "location",
    "description",
    "triage",
    "confidence",
    "sources"
  ],
  "properties": {
    "policy_number": { "type": "string" },
    "loss_date": { "type": "string", "format": "date-time" },
    "loss_type": {
      "enum": [
        "motor_collision",
        "motor_theft",
        "property_water",
        "property_fire",
        "other"
      ]
    },
    "location": {
      "type": "object",
      "required": ["text", "country"],
      "properties": {
        "text": { "type": "string" },
        "city": { "type": "string" },
        "country": { "type": "string", "pattern": "^[A-Z]{2}$" },
        "lat": { "type": "number" },
        "lon": { "type": "number" }
      }
    },
    "parties": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "role"],
        "properties": {
          "name": { "type": "string" },
          "role": { "enum": ["insured", "third_party", "witness", "unknown"] }
        }
      }
    },
    "description": { "type": "string" },
    "severity_hints": {
      "type": "object",
      "properties": {
        "injuries_reported": { "type": "boolean" },
        "vehicle_drivable": { "type": "boolean" },
        "emergency_services": { "type": "boolean" }
      }
    },
    "triage": {
      "type": "object",
      "required": ["priority"],
      "properties": {
        "priority": { "enum": ["low", "medium", "high"] },
        "reason": { "type": "string" }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "sources": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
