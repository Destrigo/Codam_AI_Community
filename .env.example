# Copy this file to .env and fill in the values.
# For core exercises, codamlings uses a local mock server in verify mode.
# For live runs, set your Mistral API key from https://console.mistral.ai

MISTRAL_API_KEY=your-mistral-key-here
MISTRAL_API_BASE=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-small-latest

# Used by exercise 01
APP_NAME=codamlings
