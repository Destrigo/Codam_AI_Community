# Copy this file to .env in the repo root (one file for ALL exercises).
# Each student uses their own Mistral key — never commit .env or share keys.
# Get a key: https://console.mistral.ai

MISTRAL_API_KEY=your-mistral-key-here
MISTRAL_API_BASE=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-small-latest

# Used by core exercise 01
APP_NAME=codam-ai-labs

# Ollama (modules/ollama) — local models, no cloud API key
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Optional — set automatically during `codam-labs verify --mock`
# CODAM_LABS_ECHO_URL=http://127.0.0.1:8765/echo
# CODAM_LABS_MCP_BASE=http://127.0.0.1:8765/mcp
# CODAM_LABS_OLLAMA_BASE=http://127.0.0.1:8765
