# Copy this file to .env in the repo root (one file for ALL exercises).
# Each student uses their own Mistral key — never commit .env or share keys.
# Get a key: https://console.mistral.ai

MISTRAL_API_KEY=your-mistral-key-here
MISTRAL_API_BASE=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-small-latest

# Used by core exercise 01
APP_NAME=codam-ai-labs

# Ollama module (live). With --mock these are set for you automatically.
# CODAM_LABS_OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Auto-set by `codam-labs --mock verify` (dynamic port — do not hardcode):
# CODAM_LABS_ECHO_URL=http://127.0.0.1:<port>/echo
# CODAM_LABS_TODO_URL=http://127.0.0.1:<port>/todos/1
# CODAM_LABS_MCP_BASE=http://127.0.0.1:<port>/mcp
# CODAM_LABS_OLLAMA_BASE=http://127.0.0.1:<port>
